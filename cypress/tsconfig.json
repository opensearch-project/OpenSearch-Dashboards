{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2018",
    "lib": ["es2018", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "cypress"]
  },
  "include": ["**/*.ts", "**/*.tsx", "../cypress.config.ts"]
}
