{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "tsBuildInfoFile": "./target/tsconfig.tsbuildinfo",
    "outDir": "target",
    "stripInternal": false,
    "declaration": true,
    "declarationMap": true,
    "types": ["jest", "node"]
  },
  "include": ["./src/**/*.ts"]
}
