{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "tsBuildInfoFile": "./target/tsconfig.tsbuildinfo",
    "declaration": true,
    "declarationDir": "./target",
    "outDir": "./target",
    "stripInternal": true,
    "declarationMap": true,
    "types": ["jest", "node"],
    "noImplicitAny": false,
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["target"]
}
